          <string>RectWidth</string>
          <int>74</int>
        </entry>
      </elementAttributes>
      <pos x="-6840" y="-2100"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>IR should point at IDCODE on test-logic-reset, and
should contain the lower bits 0b01 on capture-ir.
This does both.</string>
        </entry>
      </elementAttributes>
      <pos x="-6820" y="-2040"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>The bypass register should be 0 on its capture-dr.</string>
        </entry>
      </elementAttributes>
      <pos x="-6820" y="-1920"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>We don&apos;t have a real idcode, but we can make one up.</string>
        </entry>
      </elementAttributes>
      <pos x="-6820" y="-1800"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>We capture dmistat and rdata. The address doesn&apos;t matter,
since we&apos;re capturing a result and not issuing a command.</string>
        </entry>
      </elementAttributes>
      <pos x="-6820" y="-1700"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>Respectively:
Version 0.13 of debug spec, 
7 bits of address in dmi,
the current error code, a hint to avoid collisions,
and a bunch of dummy or write-only data.</string>
        </entry>
      </elementAttributes>
      <pos x="-6060" y="-1880"/>
    </visualElement>
    <visualElement>
      <elementName>Rectangle</elementName>
      <elementAttributes>
