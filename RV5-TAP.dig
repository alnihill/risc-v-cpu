        </entry>
      </elementAttributes>
      <pos x="-6600" y="-2680"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>The clock for the state machine.</string>
