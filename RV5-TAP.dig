          <string>Label</string>
          <string>Outputs</string>
        </entry>
        <entry>
          <string>RectWidth</string>
          <int>31</int>
        </entry>
      </elementAttributes>
      <pos x="-5340" y="-2100"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>tdo is latched out on the falling TCK.</string>
        </entry>
      </elementAttributes>
      <pos x="-5300" y="-1980"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>We hold dmi-req high from the moment
we issue a command to when we&apos;re
told it&apos;s been completed.</string>
        </entry>
      </elementAttributes>
      <pos x="-5300" y="-1900"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
