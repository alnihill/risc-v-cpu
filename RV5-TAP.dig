      </elementAttributes>
      <pos x="-6700" y="-2740"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>Which of two places to go at each state machine transition.</string>
        </entry>
      </elementAttributes>
      <pos x="-6700" y="-2660"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
