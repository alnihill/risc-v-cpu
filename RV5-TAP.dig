      </elementAttributes>
      <pos x="-6700" y="-2320"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>The status of the current operation.</string>
        </entry>
      </elementAttributes>
      <pos x="-6700" y="-2180"/>
    </visualElement>
    <visualElement>
      <elementName>Rectangle</elementName>
      <elementAttributes>
