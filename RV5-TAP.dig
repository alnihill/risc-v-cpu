      <pos x="-7900" y="-2800"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>Description</string>
          <string>I&apos;ve implemented these registers
in a way that makes them easy to
deal with under the context of
both shifting and writing by field.

If we should be shifting, we shift.
If we should be writing in parallel,
we write in parallel. It&apos;s pretty simple.</string>
        </entry>
      </elementAttributes>
      <pos x="-7900" y="-1440"/>
    </visualElement>
    <visualElement>
      <elementName>Rectangle</elementName>
      <elementAttributes>
